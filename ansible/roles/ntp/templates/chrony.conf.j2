# {{ ansible_managed }}

{% for server in ntp_servers %}
server {{ server }} iburst
{% endfor %}

# Record the rate at which the system clock gains/losses time.
driftfile /var/lib/chrony/drift

# Allow the system clock to be stepped in the first updates
# if its offset is larger than {{ chrony_makestep_threshold }} second.
makestep {{ chrony_makestep_threshold }} {{ chrony_makestep_limit }}

# Enable kernel synchronization of the real-time clock (RTC).
rtcsync

{% if ntp_allow_networks | length > 0 %}
# Allow NTP client access from networks
{% for network in ntp_allow_networks %}
allow {{ network }}
{% endfor %}
{% endif %}

# Specify directory for log files.
logdir /var/log/chrony
