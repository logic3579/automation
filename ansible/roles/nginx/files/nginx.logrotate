/opt/nginx/logs/*.log
/opt/nginx/logs/*.json
{
    daily
    rotate 7
    missingok
    notifempty
    sharedscripts
    copytruncate
    compress
    nomail
    noolddir
    dateext
    postrotate
        if [ -f /opt/nginx/logs/nginx.pid ]; then
            kill -USR1 `cat /opt/nginx/logs/nginx.pid`
        fi
    endscript
}
