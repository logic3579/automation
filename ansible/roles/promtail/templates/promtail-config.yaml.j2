# {{ ansible_managed }}
server:
  http_listen_port: {{ promtail_http_listen_port }}
  grpc_listen_port: {{ promtail_grpc_listen_port }}

positions:
  filename: {{ promtail_positions_file }}

clients:
  - url: {{ promtail_loki_url }}
{% if promtail_loki_tenant_id %}
    tenant_id: {{ promtail_loki_tenant_id }}
{% endif %}

scrape_configs:
{{ promtail_scrape_configs | to_nice_yaml(indent=2) | indent(2, first=True) }}
